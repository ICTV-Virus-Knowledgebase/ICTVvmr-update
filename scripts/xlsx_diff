#!/usr/bin/env python3
"""Command-line tool to diff two XLSX workbooks with colored output."""
from __future__ import annotations

import argparse
import sys
from collections import defaultdict
from dataclasses import dataclass
from itertools import zip_longest
import re
from typing import Dict, List, Optional, Sequence, Tuple

from openpyxl import load_workbook
from openpyxl.cell import Cell
from openpyxl.utils import get_column_letter

# surpress warnings about openpyxl not supporting conditional formatting and data validation
# since our .xlsx files use both
import warnings
warnings.filterwarnings(
    "ignore",
    message=".*Conditional Formatting extension is not supported and will be removed.*",
    category=UserWarning,
    module="openpyxl.reader.excel"
)

warnings.filterwarnings(
    "ignore",
    message=".*Data Validation extension is not supported and will be removed.*",
    category=UserWarning,
    module="openpyxl.reader.excel"
)

# ANSI color helpers
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
BOLD = "\033[1m"
RESET = "\033[0m"


@dataclass(frozen=True)
class CellDiff:
    row: int
    column: int
    old_value: Optional[str]
    new_value: Optional[str]


@dataclass(frozen=True)
class CellFormatDiff:
    row: int
    column: int
    changes: Dict[str, Tuple[str, str]]


@dataclass(frozen=True)
class ConditionalFormatDiff:
    description: str
    old_rules: Sequence[str]
    new_rules: Sequence[str]


def parse_args(argv: Sequence[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="xlsx_diff",
        description="Show a colored diff between two XLSX workbooks.",
    )
    parser.add_argument("old", help="Path to the original workbook")
    parser.add_argument("new", help="Path to the updated workbook")
    parser.add_argument(
        "--no-formatting",
        action="store_true",
        help="Suppress reporting of formatting and conditional formatting differences",
    )
    parser.add_argument(
        "--by-cell",
        action="store_true",
        help="Display each changed cell on its own line",
    )
    parser.add_argument(
        "--sheet",
        action="append",
        default=[],
        metavar="OLD_SHEET[:NEW_SHEET]",
        help="Restrict comparison to specific sheet(s). Can be repeated. Optionally map old to new sheet name.",
    )
    parser.add_argument(
        "--counts",
        action="store_true",
        help="Show only the count of rows with differences per worksheet",
    )
    parser.add_argument(
        "--ignore",
        action="append",
        default=[],
        metavar="WORKSHEET_REGEX:VALUE_REGEX",
        help="Suppress diffs for rows where any cell matches VALUE_REGEX within worksheets matching WORKSHEET_REGEX. Can be repeated.",
    )
    return parser.parse_args(argv)


def load_workbook_safe(path: str):
    try:
        return load_workbook(path, data_only=False, read_only=False)
    except FileNotFoundError:
        print(f"Unable to open workbook: {path}", file=sys.stderr)
        sys.exit(2)


def display_value(cell: Cell) -> Optional[str]:
    value = cell.value
    if value is None:
        return None
    if cell.data_type == "f" or (isinstance(value, str) and value.startswith("=")):
        return str(value)
    return repr(value) if not isinstance(value, str) else value


STYLE_ATTRIBUTES: Tuple[str, ...] = (
    "font",
    "fill",
    "border",
    "alignment",
    "number_format",
    "protection",
)


def diff_styles(old: Cell, new: Cell) -> Optional[CellFormatDiff]:
    changes: Dict[str, Tuple[str, str]] = {}
    for attr in STYLE_ATTRIBUTES:
        old_component = getattr(old, attr)
        new_component = getattr(new, attr)
        if old_component != new_component:
            if attr == "number_format":
                old_desc = str(old_component)
                new_desc = str(new_component)
            else:
                old_desc = repr(old_component)
                new_desc = repr(new_component)
            changes[attr] = (old_desc, new_desc)
    if not changes:
        return None
    return CellFormatDiff(row=old.row, column=old.column, changes=changes)


def diff_cells(
    old_ws,
    new_ws,
    *,
    include_formatting: bool = True,
) -> Tuple[List[CellDiff], List[CellFormatDiff]]:
    old_max_row = old_ws.max_row or 0
    new_max_row = new_ws.max_row or 0
    old_max_col = old_ws.max_column or 0
    new_max_col = new_ws.max_column or 0
    max_row = max(old_max_row, new_max_row)
    max_col = max(old_max_col, new_max_col)

    if max_row == 0 or max_col == 0:
        return [], []

    old_rows = old_ws.iter_rows(
        min_row=1,
        max_row=max_row,
        min_col=1,
        max_col=max_col,
    )
    new_rows = new_ws.iter_rows(
        min_row=1,
        max_row=max_row,
        min_col=1,
        max_col=max_col,
    )

    value_diffs: List[CellDiff] = []
    format_diffs: List[CellFormatDiff] = []

    for row_index in range(1, max_row + 1):
        try:
            old_row = next(old_rows)
        except StopIteration:
            old_row = ()
        try:
            new_row = next(new_rows)
        except StopIteration:
            new_row = ()

        for column_index, (old_cell, new_cell) in enumerate(
            zip_longest(old_row, new_row, fillvalue=None), start=1
        ):
            if old_cell is not None and new_cell is not None:
                same_type = old_cell.data_type == new_cell.data_type
                same_value = old_cell.value == new_cell.value
                values_equal = same_type and same_value
            else:
                values_equal = False

            if not values_equal:
                old_display = display_value(old_cell) if old_cell is not None else None
                new_display = display_value(new_cell) if new_cell is not None else None
                if old_display != new_display:
                    value_diffs.append(
                        CellDiff(
                            row=row_index,
                            column=column_index,
                            old_value=old_display,
                            new_value=new_display,
                        )
                    )

            if include_formatting and old_cell is not None and new_cell is not None:
                format_diff = diff_styles(old_cell, new_cell)
                if format_diff:
                    format_diffs.append(format_diff)

    return value_diffs, format_diffs


def parse_ignore_specs(items: Sequence[str]) -> List[Tuple[re.Pattern, re.Pattern]]:
    parsed: List[Tuple[re.Pattern, re.Pattern]] = []
    for item in items:
        if ":" not in item:
            raise ValueError(f"Invalid --ignore value '{item}' (expected WORKSHEET_REGEX:VALUE_REGEX)")
        sheet_expr, value_expr = item.split(":", 1)
        if not sheet_expr or not value_expr:
            raise ValueError(f"Invalid --ignore value '{item}' (expected WORKSHEET_REGEX:VALUE_REGEX)")
        parsed.append((re.compile(sheet_expr), re.compile(value_expr)))
    return parsed


def parse_sheet_specs(items: Sequence[str]) -> List[Tuple[str, str]]:
    pairs: List[Tuple[str, str]] = []
    for item in items:
        if not item:
            raise ValueError("Invalid --sheet value (empty)")
        if ":" in item:
            old_name, new_name = item.split(":", 1)
            if not old_name or not new_name:
                raise ValueError(f"Invalid --sheet value '{item}' (expected OLD_SHEET[:NEW_SHEET])")
            pairs.append((old_name, new_name))
        else:
            pairs.append((item, item))
    return pairs


def build_ignored_rows(new_ws, patterns: Sequence[Tuple[re.Pattern, re.Pattern]]) -> set[int]:
    if not patterns:
        return set()
    max_row = new_ws.max_row or 0
    max_col = new_ws.max_column or 0
    if max_row == 0 or max_col == 0:
        return set()

    ignored: set[int] = set()
    for r in range(1, max_row + 1):
        for c in range(1, max_col + 1):
            new_cell = new_ws.cell(r, c)
            new_text = display_value(new_cell) if new_cell.value is not None else None
            if new_text is None:
                continue
            for _sheet_re, value_re in patterns:
                if new_text is not None and value_re.search(str(new_text)):
                    ignored.add(r)
                    break
            if r in ignored:
                break
    return ignored


def describe_conditional_formatting(ws) -> Dict[str, List[str]]:
    cf_map: Dict[str, List[str]] = {}
    for cf_range in ws.conditional_formatting:
        rules = ws.conditional_formatting[cf_range]
        cf_map[cf_range] = [repr(rule) for rule in rules]
    return cf_map


def diff_conditional_formatting(old_ws, new_ws) -> List[ConditionalFormatDiff]:
    old_cf = describe_conditional_formatting(old_ws)
    new_cf = describe_conditional_formatting(new_ws)
    all_ranges = set(old_cf.keys()) | set(new_cf.keys())
    diffs: List[ConditionalFormatDiff] = []
    for cf_range in sorted(all_ranges):
        old_rules = old_cf.get(cf_range, [])
        new_rules = new_cf.get(cf_range, [])
        if old_rules != new_rules:
            diffs.append(
                ConditionalFormatDiff(
                    description=cf_range,
                    old_rules=old_rules,
                    new_rules=new_rules,
                )
            )
    return diffs


def format_cell_coordinate(row: int, column: int) -> str:
    return f"{get_column_letter(column)}{row}"


def print_value_diffs(
    sheet_name: str, diffs: List[CellDiff], *, by_cell: bool, counts_only: bool
) -> None:
    if not diffs:
        return
    if counts_only:
        rows_with_diff = len({diff.row for diff in diffs})
        print(f"{BOLD}Worksheet: {sheet_name}{RESET}")
        print(f"  Rows with differences: {rows_with_diff}")
        print()
        return
    print(f"{BOLD}Worksheet: {sheet_name}{RESET}")
    if by_cell:
        for diff in diffs:
            coord = format_cell_coordinate(diff.row, diff.column)
            old = f"{RED}{diff.old_value}{RESET}" if diff.old_value is not None else f"{RED}<empty>{RESET}"
            new = f"{GREEN}{diff.new_value}{RESET}" if diff.new_value is not None else f"{GREEN}<empty>{RESET}"
            print(f"  {coord}: {old} -> {new}")
    else:
        rows: Dict[int, List[CellDiff]] = defaultdict(list)
        for diff in diffs:
            rows[diff.row].append(diff)
        for row_index in sorted(rows):
            entries = []
            for diff in sorted(rows[row_index], key=lambda d: d.column):
                coord = get_column_letter(diff.column)
                old = (
                    f"{RED}{diff.old_value}{RESET}" if diff.old_value is not None else f"{RED}<empty>{RESET}"
                )
                new = (
                    f"{GREEN}{diff.new_value}{RESET}" if diff.new_value is not None else f"{GREEN}<empty>{RESET}"
                )
                entries.append(f"{coord}: {old} -> {new}")
            print(f"  Row {row_index}: " + ", ".join(entries))
    print()


def print_format_diffs(sheet_name: str, diffs: List[CellFormatDiff], *, counts_only: bool) -> None:
    if not diffs:
        return
    if counts_only:
        rows_with_diff = len({diff.row for diff in diffs})
        print(f"{BOLD}Formatting differences for worksheet: {sheet_name}{RESET}")
        print(f"  Rows with differences: {rows_with_diff}")
        print()
        return
    print(f"{BOLD}Formatting differences for worksheet: {sheet_name}{RESET}")
    for diff in diffs:
        coord = format_cell_coordinate(diff.row, diff.column)
        print(f"  {coord}:")
        for key, (old, new) in sorted(diff.changes.items()):
            print(f"    {key}: {RED}{old}{RESET} -> {GREEN}{new}{RESET}")
    print()


def print_conditional_diffs(
    sheet_name: str, diffs: List[ConditionalFormatDiff], *, counts_only: bool
) -> None:
    if not diffs:
        return
    if counts_only:
        print(f"{BOLD}Conditional formatting differences for worksheet: {sheet_name}{RESET}")
        print(f"  Differences: {len(diffs)}")
        print()
        return
    print(f"{BOLD}Conditional formatting differences for worksheet: {sheet_name}{RESET}")
    for diff in diffs:
        print(f"  Range {diff.description}:")
        old_desc = "\n      ".join(diff.old_rules) if diff.old_rules else "<none>"
        new_desc = "\n      ".join(diff.new_rules) if diff.new_rules else "<none>"
        print(f"    Old: {RED}{old_desc}{RESET}")
        print(f"    New: {GREEN}{new_desc}{RESET}")
    print()


def report_missing_or_new_sheets(
    old_only: Sequence[str], new_only: Sequence[str], *, counts_only: bool
) -> bool:
    if not old_only and not new_only:
        return False
    if counts_only:
        for name in old_only:
            print(f"{BOLD}Worksheet missing in new workbook: {name}{RESET}")
        for name in new_only:
            print(f"{BOLD}Worksheet missing in old workbook: {name}{RESET}")
        print()
    else:
        if old_only:
            print(f"{YELLOW}Worksheets only in old workbook: {', '.join(old_only)}{RESET}")
        if new_only:
            print(f"{YELLOW}Worksheets only in new workbook: {', '.join(new_only)}{RESET}")
        print()
    return True


def main(argv: Sequence[str]) -> int:
    args = parse_args(argv)
    try:
        ignore_specs = parse_ignore_specs(args.ignore)
        sheet_specs = parse_sheet_specs(args.sheet)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    old_wb = load_workbook_safe(args.old)
    new_wb = load_workbook_safe(args.new)

    old_sheets = set(old_wb.sheetnames)
    new_sheets = set(new_wb.sheetnames)
    if sheet_specs:
        old_sheets = {old for old, _ in sheet_specs}
        new_sheets = {new for _, new in sheet_specs}
    any_diffs = report_missing_or_new_sheets(
        sorted(old_sheets - new_sheets),
        sorted(new_sheets - old_sheets),
        counts_only=args.counts,
    )
    if sheet_specs:
        common_sheets = sheet_specs
    else:
        common_sheets = [(name, name) for name in sorted(old_sheets & new_sheets)]
    for old_name, new_name in common_sheets:
        if old_name not in old_wb.sheetnames or new_name not in new_wb.sheetnames:
            continue
        old_ws = old_wb[old_name]
        new_ws = new_wb[new_name]
        sheet_ignores = [
            spec for spec in ignore_specs if spec[0].search(old_name)
        ]
        ignored_rows = build_ignored_rows(new_ws, sheet_ignores)
        value_diffs, format_diffs = diff_cells(
            old_ws, new_ws, include_formatting=not args.no_formatting
        )
        if ignored_rows:
            value_diffs = [diff for diff in value_diffs if diff.row not in ignored_rows]
            format_diffs = [diff for diff in format_diffs if diff.row not in ignored_rows]
        cond_diffs: List[ConditionalFormatDiff] = []
        if not args.no_formatting:
            cond_diffs = diff_conditional_formatting(old_ws, new_ws)
        if value_diffs:
            any_diffs = True
            sheet_label = old_name if old_name == new_name else f"{old_name} -> {new_name}"
            print_value_diffs(
                sheet_label,
                value_diffs,
                by_cell=args.by_cell,
                counts_only=args.counts,
            )
        if not args.no_formatting and (format_diffs or cond_diffs):
            any_diffs = True
            sheet_label = old_name if old_name == new_name else f"{old_name} -> {new_name}"
            print_format_diffs(sheet_label, format_diffs, counts_only=args.counts)
            print_conditional_diffs(sheet_label, cond_diffs, counts_only=args.counts)
    if not any_diffs:
        print("No differences found.")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
